<!DOCTYPE html>
<html>
  <head>
    <title>Blog</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
  <header>
  <nav class="be-red">
  <ul class="no-list row center-xs">

  <li class="col-md logo middle-xs">
   <%=link_to "Blog Facilito"%>
  </li>
  <li class="col-md">
  <%=link_to "Inicio"%>
    
  </li>
  <li class="col-md">
  <%=link_to "Diseño"%>
    
  </li>
  <li class="col-md">
    <%=link_to "Programación"%>
  </li>
  <li class="col-md">
    <%=link_to "Tecnología"%>
  </li>

  <%if user_signed_in?%>
    <li>
      <%=link_to "Cerrar Sesión", destroy_user_session_path, method: :delete %>
    </li>
  <% end %>
  </ul>
  </nav>
  </header>
  <p class="notice"><%= notice %></p>
  <p class="alert"><%= alert %></p>
    <%= yield %>
  </body>
</html>
