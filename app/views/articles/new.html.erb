<div class="w3-container w3-black">
<h1> Crear artículo </h1>

<%= form_for(@article) do |f| %>
 
<%= f.text_field :title, placeholder: "Título", 
:class => "w3-black w3-input w3-border w3-round w3-margin" %>
<%= f.text_area :body, placeholder: "Escriba su artículo", 
:class => "w3-black w3-input w3-card w3-border w3-round w3-margin"%>
 
<%= f.submit "Guardar", :class => "w3-green w3-btn w3-margin"%>

<% end %>

</div>
